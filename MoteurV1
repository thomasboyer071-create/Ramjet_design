def oblique_shock_wave(m1, m1n, g):
    beta = np.arcsin(m1n/m1)
    theta = np.arctan(2*(1/np.tan(beta))*(m1**2 * np.sin(beta)**2 - 1) / (m1**2 * (g + np.cos(2*beta)) + 2))
    m2n = np.sqrt((m1n**2 + 2/(g-1)) / (2*g/(g-1)*m1n**2 - 1))
    m2 = m2n / np.sin(beta - theta)
    return beta, theta, m2n, m2

def calculer_geo_diffuseur(m1, me, n_chocs, g):
    m_target_oblique = np.sqrt(((me**2)+(2/(g-1)))/(2*g/(g-1)*(me**2)-1))
    k, m_last = 1.0, 2.0
    temp_thetas = np.zeros(n_chocs)
    while abs(m_target_oblique - m_last) > 0.001 and k > 0.3:
        m1n_test = m_target_oblique / k
        if m1n_test >= m1 or m1n_test <= 1: break
        m_current = m1
        for nn in range(n_chocs):
            _, th, _, m2_next = oblique_shock_wave(m_current, m1n_test, g)
            temp_thetas[nn] = th
            m_current = m2_next
        m_last = m_current
        k -= 0.0001
    if k <= 0.3: return None, None
    r_tp_oblique = (((((g+1)/2)*m1n_test**2)/(1+((g-1)/2)*m1n_test**2))**(g/(g-1))) /((2*g/(g+1)*(m1n_test**2)-((g-1)/(g+1)))**(1/(g-1)))
    r_tp_normal = (((((g+1)/2)*m_target_oblique**2)/(1+((g-1)/2)*m_target_oblique**2))**(g/(g-1)))/((2*g/(g+1)*(m_target_oblique**2)-((g-1)/(g+1)))**(1/(g-1)))
    return np.degrees(temp_thetas), (r_tp_oblique**n_chocs) * r_tp_normal


def get_atmos_isa(h):
    """ Calcule p, t, rho et a selon le modèle ISA jusqu'à 20km """
    t0_sl = 288.15      # K (Niveau mer)
    p0_sl = 101325.0    # Pa (Niveau mer)
    l_grad = 0.0065     # Gradient thermique (K/m)
    r = 287.05
    g = 9.80665
    
    if h <= 11000: # Troposphère
        t = t0_sl - l_grad * h
        p = p0_sl * (t / t0_sl)**(g / (l_grad * r))
    else: # Stratosphère (jusqu'à 20km)
        t_11 = t0_sl - l_grad * 11000
        p_11 = p0_sl * (t_11 / t0_sl)**(g / (l_grad * r))
        t = t_11 # Température constante
        p = p_11 * np.exp(-g * (h - 11000) / (r * t))
    
    rho = p / (r * t)
    a = np.sqrt(1.4 * r * t)
    return p, t, rho, a

