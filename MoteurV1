def get_beta(m, theta_deg, g=1.4):
    """Calcule beta (angle du choc) pour un Mach et un theta donnés (faible intensité)"""
    theta = np.radians(theta_deg)
    def func(beta):
        return np.tan(theta) - (2/np.tan(beta)) * (m**2 * np.sin(beta)**2 - 1) / (m**2 * (g + np.cos(2*beta)) + 2)
    
    # On cherche la solution entre l'angle de Mach et 90°
    from scipy.optimize import brentq
    beta_min = np.arcsin(1/m) + 1e-5
    return brentq(func, beta_min, np.pi/2 - 1e-5)

