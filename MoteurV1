import cantera as ct
import numpy as np
import scipy.optimize as opt
import matplotlib.pyplot as plt

# --- SOUS-FONCTIONS GÉOMÉTRIE DIFFUSEUR (Traduites de ton MATLAB) ---

def oblique_shock_wave(M1, M1n, g):
    beta = np.arcsin(M1n/M1)
    # Formule theta-beta-Mach
    theta = np.arctan(2*(1/np.tan(beta))*(M1**2 * np.sin(beta)**2 - 1) / (M1**2 * (g + np.cos(2*beta)) + 2))
    M2n = np.sqrt((M1n**2 + 2/(g-1)) / (2*g/(g-1)*M1n**2 - 1))
    M2 = M2n / np.sin(beta - theta)
    return beta, theta, M2n, M2

def calculer_geo_diffuseur(M1, Me, n_chocs, g=1.4):
    # Me est le Mach avant le choc droit
    M_target_oblique = np.sqrt(((Me**2)+(2/(g-1)))/(2*g/(g-1)*(Me**2)-1))
    
    k = 1.0
    M_last = 2.0
    M1n_test = 0
    temp_thetas = np.zeros(n_chocs)
    
    while abs(M_target_oblique - M_last) > 0.001 and k > 0.3:
        M1n_test = M_target_oblique / k
        if M1n_test >= M1 or M1n_test <= 1:
            break
        
        M_current = M1
        for nn in range(n_chocs):
            _, th, _, M2_next = oblique_shock_wave(M_current, M1n_test, g)
            temp_thetas[nn] = th
            M_current = M2_next
        
        M_last = M_current
        k -= 0.0001
        
    if k <= 0.3 or M1n_test >= M1:
        return None, None
    else:
        # Calcul du rendement de pression totale
        r_tp_oblique = (((((g+1)/2)*M1n_test**2)/(1+((g-1)/2)*M1n_test**2))**(g/(g-1))) / \
                       ((2*g/(g+1)*(M1n_test**2)-((g-1)/(g+1)))**(1/(g-1)))
        r_tp_normal = (((((g+1)/2)*M_target_oblique**2)/(1+((g-1)/2)*M_target_oblique**2))**(g/(g-1))) / \
                      ((2*g/(g+1)*(M_target_oblique**2)-((g-1)/(g+1)))**(1/(g-1)))
        
        rendement = (r_tp_oblique**n_chocs) * r_tp_normal
        return np.degrees(temp_thetas), rendement

# --- PROGRAMME PRINCIPAL ---

gas = ct.Solution('nDodecane_Reitz.yaml')
fuel, oxidizer = 'c12h26', {'O2': 1.0, 'N2': 3.76}
LHV = 44.1e6      # J/kg
eta_comb = 0.98
F_target = 10000  # N
M1_vol = 2.7
P1, T1 = 7504.8, 216.65 # 18km

# --- 3. CALCUL DIFFUSEUR ---

Me_diff = 0.8
n_rampes = 3
thetas, eta_diff = calculer_geo_diffuseur(M1_vol, Me_diff, n_rampes, 1.4)

T01 = T1 * (1 + 0.2 * M1_vol**2)
P01 = P1 * (1 + 0.2 * M1_vol**2)**3.5
P02 = P01 * eta_diff
T02 = T01 

# --- 4. CHAMBRE DE COMBUSTION (MÉTHODE RAYLEIGH AVEC LHV) ---

phi = 0.45
M2_in = 0.3 # Mach entrée chambre

# Utilisation de Cantera pour Cp et Gamma précis
gas.set_equivalence_ratio(phi, fuel=fuel, oxidizer=oxidizer)
T2_stat = T02 / (1 + 0.2 * M2_in**2)
gas.TP = T2_stat, P02 / (1 + 0.2 * M2_in**2)**3.5

cp_in = gas.cp_mass
gamma_in = gas.cp_mass / gas.cv_mass

# Simulation d'une combustion HP pour avoir le Cp de sortie
gas.equilibrate('HP')
cp_out = gas.cp_mass
gamma_out = gas.cp_mass / gas.cv_mass
R_gaz = ct.gas_constant / gas.mean_molecular_weight

# Calcul du T03 via Rayleigh (LHV)
cp_mean = (cp_in + cp_out) / 2
gamma_mean = (gamma_in + gamma_out) / 2
gas.set_equivalence_ratio(1.0, fuel=fuel, oxidizer=oxidizer) # Pour fst
y_f_st = gas.mass_fraction_dict()[fuel]
fst = y_f_st / (1 - y_f_st)
f = phi * fst

q = (f / (1 + f)) * LHV * eta_comb
T03 = T02 + q / cp_mean

# Résolution Mach de sortie M3
def rayleigh_solve(M):
    ratio_target = T02 / T03
    val = ((M2_in/M)**2 * ((1 + gamma_mean*M**2)/(1 + gamma_mean*M2_in**2))**2 * (1 + (gamma_mean-1)/2 * M**2) / (1 + (gamma_mean-1)/2 * M2_in**2))
    return val - ratio_target

M3 = opt.fsolve(rayleigh_solve, 0.5)[0]

# Pressions via Rayleigh
P2_stat = P02 / (1 + (gamma_in-1)/2 * M2_in**2)**(gamma_in/(gamma_in-1))
P3_stat = P2_stat * (1 + gamma_mean * M2_in**2) / (1 + gamma_mean * M3**2)
P03 = P3_stat * (1 + (gamma_mean-1)/2 * M3**2)**(gamma_mean/(gamma_mean-1))

# --- 5. TUYÈRE & DIMENSIONS ---

P4 = P1
M4 = np.sqrt((2/(gamma_out-1)) * ((P03/P4)**((gamma_out-1)/gamma_out) - 1))
T4 = T03 / (1 + (gamma_out-1)/2 * M4**2)
u4 = M4 * np.sqrt(gamma_out * R_gaz * T4)
u1 = M1_vol * np.sqrt(1.4 * 287 * T1)
mdot = F_target / (u4 - u1)

# Sections
A1 = mdot / (0.1207 * u1)
rho2 = P2_stat / (287 * T2_stat)
A2 = mdot / (rho2 * M2_in * np.sqrt(gamma_in * 287 * T2_stat))
A_col = (mdot * np.sqrt(T03)) / (P03 * np.sqrt(gamma_out/R_gaz) * (2/(gamma_out+1))**((gamma_out+1)/(2*(gamma_out-1))))
A4 = (A_col/M4) * ((2/(gamma_out+1))*(1+(gamma_out-1)/2*M4**2))**((gamma_out+1)/(2*(gamma_out-1)))

print(f"=== RÉSULTATS RAYLEIGH (LHV) ===\n")
print(f"T03 (Rayleigh LHV) : {T03:.1f} K")
print(f"Mach sortie M3     : {M3:.3f}")
print(f"Pression totale P03: {P03/1e5:.3f} bar")
print("-" * 30)
print(f"Diamètre D2 (Chambre) : {200*np.sqrt(A2/np.pi):.2f} cm")
print(f"Diamètre Dt (Col)     : {200*np.sqrt(A_col/np.pi):.2f} cm")