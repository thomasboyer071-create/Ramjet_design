import cantera as ct
import numpy as np
import matplotlib.pyplot as plt
import os

# S'assurer qu'on est dans le bon dossier pour trouver le fichier .yaml
os.chdir(os.path.dirname(os.path.abspath(__file__)))

# Initialisation
gas = ct.Solution('nDodecane_Reitz.yaml')
T0 = 523.1
P0 = ct.one_atm

# Détection automatique du nom du carburant dans le mécanisme
fuel_species = 'c12h26' 
oxidizer_mix = {'O2': 1.0, 'N2': 3.76}

# --- CALCUL DE FST (Méthode robuste) ---
# On règle à la stoechiométrie
gas.set_equivalence_ratio(1.0, fuel=fuel_species, oxidizer=oxidizer_mix)
# f = masse_carburant / masse_oxydant
# Dans Cantera, Y est la fraction massique. 
# Y_fuel = m_f / (m_f + m_a)  => f = Y_fuel / Y_oxidizer
y_fuel_st = gas.mass_fraction_dict()[fuel_species]
f_st = y_fuel_st / (1.0 - y_fuel_st)

print(f"Rapport stœchiométrique (fst) pour {fuel_species}: {f_st:.5f}")

# --- BOUCLE ---
phis = np.linspace(0.5, 4.0, 100)
Tad = []
f_ratios = []

for phi in phis:
    # On définit le mélange pour le phi actuel
    gas.set_equivalence_ratio(phi, fuel=fuel_species, oxidizer=oxidizer_mix)
    
    # Calcul du rapport massique réel f = mf/ma
    # f = phi * fst
    f_ratios.append(phi * f_st)
    
    gas.TP = T0, P0
    gas.equilibrate('HP')
    Tad.append(gas.T)

# --- PLOT ---
fig, ax1 = plt.subplots(figsize=(10, 6))

color = 'tab:red'
ax1.set_xlabel('Equivalence ratio (phi)')
ax1.set_ylabel('Adiabatic flame temperature (K)', color=color)
ax1.plot(phis, Tad, color=color, lw=2)
ax1.tick_params(axis='y', labelcolor=color)
ax1.grid(True, alpha=0.3)

ax2 = ax1.twinx()
color = 'tab:blue'
ax2.set_ylabel('Mass ratio f = mf/ma', color=color)
ax2.plot(phis, f_ratios, color=color, linestyle='--')
ax2.tick_params(axis='y', labelcolor=color)

plt.title(f'Combustion n-Dodécane/Air\nEvolution de Tad et du rapport massique f')
plt.show()